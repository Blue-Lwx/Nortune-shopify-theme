<section class="section section--muted" id="faq">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
    </div>

    <div class="faq">
      {% for block in section.blocks %}
        <details {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <p class="text-muted">{{ block.settings.answer }}</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Got questions?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you need to know"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Does it emit light?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "No. The case does not emit light by itself. It absorbs light and shows a subtle glow in darker environments."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ preview",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does the glow last?", "answer": "After full light exposure, the glow lasts 2-4 hours at its brightest, then gradually fades. A few minutes under any light source recharges it." } },
        { "type": "faq", "settings": { "question": "Which AirPods models does it fit?", "answer": "The case is compatible with popular AirPods charging cases. Use your Shopify product options or description for exact model compatibility." } },
        { "type": "faq", "settings": { "question": "Does it interfere with wireless charging?", "answer": "No. The case is designed to work with both wireless and wired charging without removing it." } }
      ]
    }
  ]
}
{% endschema %}
