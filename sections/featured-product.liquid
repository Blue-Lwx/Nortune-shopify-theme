{% liquid
  assign featured_product = section.settings.product
  assign product_url = section.settings.cta_link
  if featured_product != blank
    assign product_url = featured_product.url
  endif
  if product_url == blank
    assign product_url = routes.all_products_collection_url
  endif

  assign white_product_image = 'product-blue.jpeg' | asset_url
  assign orange_product_image = 'product-orange.jpeg' | asset_url

  if featured_product.featured_media
    assign white_product_image = featured_product.featured_media.preview_image | image_url: width: 900
  endif

  for media in featured_product.media
    if media.preview_image
      assign media_src = media.preview_image | image_url: width: 900
      assign media_src_downcase = media_src | downcase
      if media_src_downcase contains 'orange'
        assign orange_product_image = media_src
      elsif media_src_downcase contains 'white' or media_src_downcase contains 'black'
        assign white_product_image = media_src
      endif
    endif
  endfor
%}

<section class="section">
  <div class="container">
    <div class="section-intro section-intro--product-showcase">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="text-muted">{{ section.settings.text }}</p>
    </div>

    <div class="grid-2 product-showcase-grid">
      <a class="product-card product-card--link" href="{{ product_url }}" aria-label="Shop White case">
        <img class="product-card__image" src="{{ white_product_image }}" alt="White glow AirPods case" width="900" height="900" loading="lazy">
        <div class="product-card__overlay">
          <h3 class="product-card__title">White</h3>
          <div class="product-card__meta-row">
            <p class="text-muted">
              {% if featured_product.price %}
                {{ featured_product.price | money }}
              {% else %}
                $29.99
              {% endif %}
            </p>
            <span class="product-card__tag">Popular choice</span>
          </div>
        </div>
      </a>

      <a class="product-card product-card--link" href="{{ product_url }}" aria-label="Shop Orange case">
        <img class="product-card__image" src="{{ orange_product_image }}" alt="Orange glow AirPods case" width="900" height="900" loading="lazy">
        <div class="product-card__overlay">
          <h3 class="product-card__title">Orange</h3>
          <div class="product-card__meta-row">
            <p class="text-muted">$29.99</p>
            <span class="product-card__tag product-card__tag--orange">Selling fast</span>
          </div>
        </div>
      </a>
    </div>

    <div class="center" style="margin-top: 3rem;">
      <a class="button" href="{{ product_url }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Six colors"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your glow"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A clean AirPods case that stays low-key in daylight and glows softly when the room goes dark."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Get Yours Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Fallback CTA link"
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
