{% liquid
  assign featured_product = section.settings.product
  assign product_url = section.settings.cta_link
  if featured_product != blank
    assign product_url = featured_product.url
  endif
  if product_url == blank
    assign product_url = routes.all_products_collection_url
  endif
%}

<section class="section">
  <div class="container">
    <div class="section-intro section-intro--product-showcase">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      <p class="text-muted">{{ section.settings.text }}</p>
    </div>

    <div class="grid-2 product-showcase-grid">
      <article class="product-card">
        {% if featured_product.featured_image %}
          {{ featured_product.featured_image | image_url: width: 900 | image_tag: class: 'product-card__image', loading: 'lazy', alt: featured_product.title }}
        {% else %}
          <img class="product-card__image" src="{{ 'product-blue.jpeg' | asset_url }}" alt="Blue glow AirPods case" width="1824" height="1824" loading="lazy">
        {% endif %}
        <div class="product-card__overlay">
          <h3 class="product-card__title">White</h3>
          <div class="product-card__meta-row">
            <p class="text-muted">
              {% if featured_product.price %}
                {{ featured_product.price | money }}
              {% else %}
                $29.99
              {% endif %}
            </p>
            <span class="product-card__tag">Popular choice</span>
          </div>
        </div>
      </article>

      <article class="product-card">
        <img class="product-card__image" src="{{ 'product-orange.jpeg' | asset_url }}" alt="Orange glow AirPods case" width="1920" height="1829" loading="lazy">
        <div class="product-card__overlay">
          <h3 class="product-card__title">Orange</h3>
          <div class="product-card__meta-row">
            <p class="text-muted">$29.99</p>
            <span class="product-card__tag product-card__tag--orange">Selling fast</span>
          </div>
        </div>
      </article>
    </div>

    <div class="center" style="margin-top: 3rem;">
      <a class="button" href="{{ product_url }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Six colors"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your glow"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A clean AirPods case that stays low-key in daylight and glows softly when the room goes dark."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Get Yours Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Fallback CTA link"
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
