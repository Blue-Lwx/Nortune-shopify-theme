<section class="section center">
  <div class="container">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="heading-lg">{{ section.settings.heading }}</h1>
    <p class="text-muted" style="max-width: 520px; margin: 1rem auto 2rem;">{{ section.settings.text }}</p>
    <a class="button" href="{{ routes.root_url }}">{{ section.settings.cta_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This page wandered into the dark."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Head back home and pick up where the glow is."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Back to home"
    }
  ]
}
{% endschema %}
