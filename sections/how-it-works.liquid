<section class="section section--muted">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p class="text-muted">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="steps">
      <div class="step">
        <div class="step__icon" aria-hidden="true">Light</div>
        <h3 class="heading-md" style="font-size: 1.35rem;">{{ section.settings.step_one_title }}</h3>
        <p class="text-muted">{{ section.settings.step_one_text }}</p>
      </div>
      <div class="text-muted" aria-hidden="true">then</div>
      <div class="step">
        <div class="step__icon" style="background: rgba(0, 191, 255, 0.12);" aria-hidden="true">Glow</div>
        <h3 class="heading-md" style="font-size: 1.35rem;">{{ section.settings.step_two_title }}</h3>
        <p class="text-muted">{{ section.settings.step_two_text }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How it works"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "step_one_title",
      "label": "Step one title",
      "default": "Absorbs light during the day"
    },
    {
      "type": "textarea",
      "id": "step_one_text",
      "label": "Step one text",
      "default": "Natural or artificial light charges the phosphorescent layer."
    },
    {
      "type": "text",
      "id": "step_two_title",
      "label": "Step two title",
      "default": "Reveals a soft glow in the dark"
    },
    {
      "type": "textarea",
      "id": "step_two_text",
      "label": "Step two text",
      "default": "A subtle, calming glow that fades naturally over time."
    }
  ],
  "presets": [
    {
      "name": "How it works"
    }
  ]
}
{% endschema %}
