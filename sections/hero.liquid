{% liquid
  assign hero_image = section.settings.image
  assign fallback_image = 'hero-image.jpg' | asset_url
  assign cta_product = section.settings.cta_product
  assign cta_link = section.settings.cta_link
  if cta_product != blank
    assign cta_link = cta_product.url
  endif
  if cta_link == blank
    assign cta_link = routes.all_products_collection_url
  endif
  assign secondary_link = section.settings.secondary_link | default: cta_link
%}

<section class="hero">
  <div class="hero__image">
    {% if hero_image != blank %}
      {{ hero_image | image_url: width: 2200 | image_tag: loading: 'eager', alt: section.settings.image_alt }}
    {% else %}
      <img src="{{ fallback_image }}" alt="{{ section.settings.image_alt | escape }}" width="720" height="617" loading="eager">
    {% endif %}
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <p class="eyebrow eyebrow--blue">{{ section.settings.eyebrow }}</p>
    <h1 class="heading-xl">
      {{ section.settings.heading_prefix }}
      <span class="text-glow">{{ section.settings.heading_highlight }}</span>
    </h1>
    <p class="text-muted">{{ section.settings.subtext }}</p>
    <div class="button-row button-row--center">
      <a class="button" href="{{ cta_link }}">{{ section.settings.cta_label }}</a>
      <a class="button button--outline" href="{{ secondary_link }}">{{ section.settings.secondary_label }}</a>
    </div>
    <div class="trust-line" aria-label="Store guarantees">
      <span>Fast Shipping</span>
      <span>Secure Checkout</span>
      <span>14-Day Guarantee</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Glow-in-the-dark AirPods case in a dark setting"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Selling fast - Limited stock"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading prefix",
      "default": "Never lose your AirPods "
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight",
      "default": "in the dark again"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "A premium AirPods case with a phosphorescent glow - spot it instantly in any dark room."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Get Yours Now"
    },
    {
      "type": "product",
      "id": "cta_product",
      "label": "CTA product"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Fallback CTA link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary CTA label",
      "default": "Choose Your Glow"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
