{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign single_total = 3399
  assign two_total = 4899
  assign three_total = 5899
  assign two_compare = 6798
  assign three_compare = 10197
  assign two_savings = 1899
  assign three_savings = 4298
  assign product_form_id = 'product-form-' | append: section.id
  assign blue_product_image = 'nocturne-blue.jpeg' | asset_url
  assign white_product_image = 'nocturne-white.png' | asset_url
  assign orange_product_image = 'nocturne-orange.jpeg' | asset_url

  for media in product.media
    if media.preview_image
      assign media_src = media.preview_image | image_url: width: 1200
      assign media_src_downcase = media_src | downcase
      if media_src_downcase contains 'orange'
        assign orange_product_image = media_src
      endif
    endif
  endfor
%}

<section class="product-main">
  <div class="container product-layout">
    <div class="product-gallery" data-product-gallery>
      <div class="product-gallery__main">
        <img
          data-gallery-main
          src="{{ blue_product_image }}"
          alt="Nocturne Aura Case in Blue"
          width="2048"
          height="2048"
        >
      </div>

      <div class="product-gallery__thumbs" aria-label="Product images">
        {% assign aura_thumbs = 'Blue|White|Orange' | split: ',' %}
        {% for thumb in aura_thumbs %}
          {% assign thumb_parts = thumb | split: '|' %}
          {% assign thumb_color = thumb_parts[0] %}
          {% assign thumb_image = blue_product_image %}
          {% if thumb_color == 'White' %}
            {% assign thumb_image = white_product_image %}
          {% elsif thumb_color == 'Orange' %}
            {% assign thumb_image = orange_product_image %}
          {% endif %}
          <button
            type="button"
            class="{% if forloop.first %}is-active{% endif %}"
            data-gallery-thumb
            data-image-src="{{ thumb_image }}"
            data-image-alt="Nocturne Aura Case in {{ thumb_color }}"
            {% if forloop.first %}aria-current="true"{% endif %}
            aria-label="View {{ thumb_color }} image"
          >
            <img src="{{ thumb_image }}" alt="Nocturne Aura Case in {{ thumb_color }}" width="180" height="180" loading="lazy">
          </button>
        {% endfor %}

        {% if product.media.size > 0 %}
          {% for media in product.media %}
            {% if media.preview_image %}
              {% assign media_alt = media.alt | default: product.title %}
              <button
                type="button"
                class="{% if forloop.first %}is-active{% endif %}"
                data-gallery-thumb
                data-image-src="{{ media.preview_image | image_url: width: 1200 }}"
                data-image-alt="{{ media.alt | default: product.title | escape }}"
                {% if forloop.first %}aria-current="true"{% endif %}
                aria-label="View image {{ forloop.index }}"
              >
                <img src="{{ media.preview_image | image_url: width: 180 }}" alt="{{ media_alt | escape }}" width="{{ media.preview_image.width }}" height="{{ media.preview_image.height }}" loading="lazy">
              </button>
            {% endif %}
          {% endfor %}
        {% else %}
          {% assign fallback_images = 'nocturne-blue.jpeg,nocturne-white.png,nocturne-orange.jpeg' | split: ',' %}
          {% for fallback in fallback_images %}
            <button
              type="button"
              data-gallery-thumb
              data-image-src="{{ fallback | asset_url }}"
              data-image-alt="Nocturne Aura Case"
              aria-label="View image {{ forloop.index }}"
            >
              <img src="{{ fallback | asset_url }}" alt="Nocturne Aura Case" width="180" height="180" loading="lazy">
            </button>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-xl product-title">{{ section.settings.display_title }}</h1>

      <div class="product-review-line">
        <div class="stars" aria-label="5 out of 5 stars">
          {% for i in (1..5) %}
            {% render 'icon-star' %}
          {% endfor %}
        </div>
        <span class="text-muted">{{ section.settings.review_preview }}</span>
      </div>

      <div class="product-description text-muted">
        <p><strong>Nocturne Aura Case</strong></p>
        <p>Glow in the dark. Find it instantly. Carry it anywhere.</p>
        <p>Tired of losing your AirPods in the dark?</p>
        <p>The Nocturne Aura Case transforms your everyday carry into something you’ll never misplace again. Designed with a smooth, glowing aura effect, it charges with light during the day and emits a soft, vibrant glow when you need it most.</p>
        <p>Simple. Functional. Addictively aesthetic.</p>
      </div>

      <div class="product-price product-price--bundle" data-bundle-price-target>
        <span class="price-final" data-bundle-now>{{ two_total | money }}</span>
        <span class="price-compare" data-bundle-was>{{ two_compare | money }}</span>
        <span class="price-save" data-bundle-save>Save {{ two_savings | money }}</span>
      </div>

      {% form 'product', product, id: product_form_id, class: 'product-form', data-product-builder: '' %}
        <input type="hidden" name="quantity" value="2" data-bundle-quantity>
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>
        <input type="hidden" name="properties[Bundle]" value="Buy 2" data-bundle-property>
        <input type="hidden" name="properties[Color]" value="" data-color-property>
        <input type="hidden" name="properties[AirPods model]" value="" data-model-property>

        <script type="application/json" data-product-variants-json>
          [
            {% for variant in product.variants %}
              {
                "id": {{ variant.id | json }},
                "available": {{ variant.available | json }},
                "option1": {{ variant.option1 | json }},
                "option2": {{ variant.option2 | json }},
                "option3": {{ variant.option3 | json }},
                "options": {{ variant.options | json }},
                "inventory_management": {{ variant.inventory_management | json }},
                "inventory_policy": {{ variant.inventory_policy | json }},
                "inventory_quantity": {{ variant.inventory_quantity | json }},
                "requires_shipping": {{ variant.requires_shipping | json }},
                "weight": {{ variant.weight | json }},
                "grams": {{ variant.weight | json }},
                "title": {{ variant.title | json }}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        </script>

        <div class="product-builder">
          <div class="selector-group">
            <div class="selector-heading">
              <div>
                <p class="selector-label">Choose your bundle first</p>
                <p class="selector-hint">Pick the quantity you want. The selected quantity is sent directly to Shopify cart.</p>
              </div>
            </div>

            <div class="bundle-list bundle-list--compact" aria-label="Choose bundle">
              <button
                class="bundle-card"
                type="button"
                data-bundle-card
                data-quantity="1"
                data-title="Buy 1"
                data-total="{{ single_total | money }}"
                data-now="{{ single_total | money }}"
                data-was=""
                data-savings="$0.00"
                data-save-label=""
                aria-pressed="false"
              >
                <span class="bundle-card__top">
                  <span>
                    <span class="bundle-card__title">Buy 1</span>
                    <span class="bundle-card__deal"><strong>{{ single_total | money }}</strong></span>
                  </span>
                  <strong class="bundle-card__price">{{ single_total | money }}</strong>
                </span>
              </button>

              <button
                class="bundle-card is-selected"
                type="button"
                data-bundle-card
                data-quantity="2"
                data-title="Buy 2"
                data-total="{{ two_total | money }}"
                data-now="{{ two_total | money }}"
                data-was="{{ two_compare | money }}"
                data-savings="{{ two_savings | money }}"
                data-save-label="Save {{ two_savings | money }}"
                aria-pressed="true"
              >
                <span class="bundle-card__top">
                  <span>
                    <span class="bundle-card__title">Buy 2 <span class="badge">Most Popular</span></span>
                    <span class="bundle-card__deal"><s>{{ two_compare | money }}</s> <strong>{{ two_total | money }}</strong></span>
                    <span class="text-muted">Save {{ two_savings | money }}</span>
                  </span>
                  <strong class="bundle-card__price">{{ two_total | money }}</strong>
                </span>
              </button>

              <button
                class="bundle-card"
                type="button"
                data-bundle-card
                data-quantity="3"
                data-title="Buy 3"
                data-total="{{ three_total | money }}"
                data-now="{{ three_total | money }}"
                data-was="{{ three_compare | money }}"
                data-savings="{{ three_savings | money }}"
                data-save-label="Save {{ three_savings | money }}"
                aria-pressed="false"
              >
                <span class="bundle-card__top">
                  <span>
                    <span class="bundle-card__title">Buy 3 <span class="badge badge--blue">Best Value</span></span>
                    <span class="bundle-card__deal"><s>{{ three_compare | money }}</s> <strong>{{ three_total | money }}</strong></span>
                    <span class="text-muted">Save {{ three_savings | money }}</span>
                  </span>
                  <strong class="bundle-card__price">{{ three_total | money }}</strong>
                </span>
              </button>
            </div>
          </div>

          {% assign model_option = product.options_by_name['Applicable models'] %}
          {% if model_option == blank %}
            {% assign model_option = product.options_by_name['Model'] %}
          {% endif %}
          {% if model_option == blank %}
            {% assign model_option = product.options_by_name['AirPods model'] %}
          {% endif %}
          {% comment %}
            TODO Shopify Admin: split the combined model option values into separate
            variants if inventory needs to track AirPods 1, AirPods 2, AirPods Pro 1,
            and AirPods Pro 2 independently. Current product data uses combined
            AirPods 1/2 and AirPods Pro 1/2 option values.
          {% endcomment %}
          {% assign color_options = 'Blue,Green,Purple,Red,White,Orange' | split: ',' %}

          <div class="selector-group selector-group--items">
            <div class="selector-heading">
              <div>
                <p class="selector-label">Build each case</p>
                <p class="selector-hint">Choose an AirPods model and color for every item in your bundle.</p>
              </div>
              <span class="required-pill">Required</span>
            </div>

            <div class="bundle-item-list" data-bundle-items>
              {% for item_index in (1..3) %}
                <div class="bundle-item" data-bundle-item data-item-index="{{ item_index }}" {% if item_index > 2 %}hidden{% endif %}>
                  <div class="bundle-item__header">
                    <strong>Item {{ item_index }}</strong>
                    <span data-item-summary="{{ item_index }}">Choose model and color</span>
                  </div>

                  <div class="bundle-item__section">
                    <p class="color-picker__label">Item {{ item_index }} model</p>
                    <div class="option-grid option-grid--compatibility" role="radiogroup" aria-label="Item {{ item_index }} model">
                      {% if model_option != blank %}
                        {% for model_value in model_option.values %}
                          {% assign model_label = model_value %}
                          {% if model_value == 'AirPods 1 2 Default' %}
                            {% assign model_label = 'AirPods 1/2' %}
                          {% elsif model_value == 'AirPods Pro 1 2 Default' %}
                            {% assign model_label = 'AirPods Pro 1/2' %}
                          {% endif %}

                          <button
                            type="button"
                            class="option-button"
                            data-item-model-option
                            data-item-index="{{ item_index }}"
                            data-value="{{ model_label | escape }}"
                            data-option-value="{{ model_value | escape }}"
                            aria-pressed="false"
                          >
                            {{ model_label }}
                          </button>
                        {% endfor %}
                      {% else %}
                        <p class="selector-hint">Add an AirPods model option to this product in Shopify Admin to enable model-specific inventory.</p>
                      {% endif %}
                    </div>
                  </div>

                  <div class="bundle-item__section">
                    <p class="color-picker__label">Item {{ item_index }} color</p>
                    <div class="color-swatch-grid" role="radiogroup" aria-label="Item {{ item_index }} color">
                      {% for color in color_options %}
                        {% assign color_handle = color | handleize %}
                        {% assign color_variant = blank %}
                        {% assign color_option_value = blank %}
                        {% for variant in product.variants %}
                          {% assign variant_color_text = variant.option1 | default: variant.title | downcase %}
                          {% if color_variant == blank %}
                            {% case color %}
                              {% when 'White' %}
                                {% if variant_color_text contains 'white' %}
                                  {% assign color_variant = variant %}
                                  {% assign color_option_value = variant.option1 %}
                                {% endif %}
                              {% when 'Blue' %}
                                {% if variant_color_text contains 'blue' %}
                                  {% assign color_variant = variant %}
                                  {% assign color_option_value = variant.option1 %}
                                {% endif %}
                              {% when 'Green' %}
                                {% if variant_color_text contains 'green' %}
                                  {% assign color_variant = variant %}
                                  {% assign color_option_value = variant.option1 %}
                                {% endif %}
                              {% when 'Purple' %}
                                {% if variant_color_text contains 'purple' %}
                                  {% assign color_variant = variant %}
                                  {% assign color_option_value = variant.option1 %}
                                {% endif %}
                              {% when 'Red' %}
                                {% if variant_color_text contains 'red' %}
                                  {% assign color_variant = variant %}
                                  {% assign color_option_value = variant.option1 %}
                                {% endif %}
                              {% when 'Orange' %}
                                {% if variant_color_text contains 'orange' %}
                                  {% assign color_variant = variant %}
                                  {% assign color_option_value = variant.option1 %}
                                {% endif %}
                            {% endcase %}
                          {% endif %}
                        {% endfor %}

                        {% assign color_image = blue_product_image %}
                        {% if color == 'White' %}
                          {% assign color_image = white_product_image %}
                        {% elsif color == 'Orange' %}
                          {% assign color_image = orange_product_image %}
                        {% elsif color_variant.featured_media %}
                          {% assign color_image = color_variant.featured_media.preview_image | image_url: width: 1200 %}
                        {% elsif color_variant.image %}
                          {% assign color_image = color_variant.image | image_url: width: 1200 %}
                        {% endif %}

                        {% assign is_available = false %}
                        {% if color_variant != blank and color_variant.available %}
                          {% assign is_available = true %}
                        {% endif %}

                        <button
                          type="button"
                          class="color-swatch color-swatch--{{ color_handle }}"
                          data-item-color-option
                          data-item-index="{{ item_index }}"
                          data-value="{{ color }}"
                          data-option-value="{{ color_option_value | escape }}"
                          data-color-image="{{ color_image }}"
                          data-available="{{ is_available }}"
                          aria-pressed="false"
                          aria-label="Item {{ item_index }} {{ color }}"
                          {% unless is_available %}disabled{% endunless %}
                        >
                          <span class="color-swatch__image">
                            <img src="{{ color_image }}" alt="" width="120" height="120" loading="lazy">
                            <span class="color-swatch__tone"></span>
                          </span>
                          <strong>{{ color }}</strong>
                        </button>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="bundle-lines" data-bundle-lines hidden>
            <p class="selector-label">Selected cases</p>
            <ul data-bundle-lines-list></ul>
          </div>

          <ul class="builder-benefits">
            <li>{% render 'icon-check' %} Fits your selected AirPods model</li>
            <li>{% render 'icon-check' %} Shock-resistant shell</li>
            <li>{% render 'icon-check' %} Glow-in-the-dark finish</li>
            <li>{% render 'icon-check' %} Easy access to charging port</li>
          </ul>

          <div class="builder-summary" aria-live="polite">
            <div>
              <span>Bundle</span>
              <strong data-summary-bundle>Buy 2</strong>
            </div>
            <div>
              <span>Color</span>
              <strong data-summary-color>Choose a color</strong>
            </div>
            <div>
              <span>AirPods model</span>
              <strong data-summary-model>Choose a model</strong>
            </div>
            <div>
              <span>Final price</span>
              <strong data-summary-price>{{ two_total | money }}</strong>
            </div>
            <div>
              <span>Savings</span>
              <strong data-summary-savings>Save {{ two_savings | money }}</strong>
            </div>
          </div>

          <p class="form-error" data-builder-error hidden>Please choose a color and AirPods model before adding to cart.</p>
        </div>

        <button class="button" type="submit" style="width: 100%;" data-builder-submit disabled {% unless current_variant.available %}data-sold-out disabled{% endunless %}>
          {% if current_variant.available %}
            <span data-submit-price-label>Add 2 to cart - {{ two_total | money }}</span>
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      {% endform %}

      <ul class="product-benefits product-benefits--secondary">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <li {{ block.shopify_attributes }}>{% render 'icon-check' %} {{ block.settings.text }}</li>
          {% endif %}
        {% endfor %}
      </ul>

      <div class="trust-grid">
        <div class="trust-item">{{ section.settings.shipping_text }}</div>
        <div class="trust-item">{{ section.settings.returns_text }}</div>
        <div class="trust-item">{{ section.settings.checkout_text }}</div>
      </div>
    </div>
  </div>
</section>

<div class="mobile-sticky-atc">
  <div>
    <strong data-mobile-price>{{ two_total | money }}</strong>
    <div class="text-muted" style="font-size: 0.75rem;" data-mobile-bundle-label>Buy 2</div>
  </div>
  <button class="button" type="submit" form="product-form-{{ section.id }}" disabled {% unless current_variant.available %}data-sold-out{% endunless %}>
    <span data-submit-price-label>Add 2 to cart - {{ two_total | money }}</span>
  </button>
</div>

<section class="section section--muted">
  <div class="container grid-2 product-details-grid">
    <div class="grid-2 product-highlight-grid">
      {% for block in section.blocks %}
        {% if block.type == 'highlight' %}
          <article class="info-card" {{ block.shopify_attributes }}>
            <div class="icon-pill">{% render 'icon-check' %}</div>
            <h2 class="heading-md" style="font-size: 1.2rem;">{{ block.settings.title }}</h2>
            <p class="text-muted">{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div>
      <p class="eyebrow">{{ section.settings.details_eyebrow }}</p>
      <h2 class="heading-lg">{{ section.settings.details_heading }}</h2>
      <p class="text-muted">{{ section.settings.details_text }}</p>
      <ul class="product-benefits">
        <li>{% render 'icon-check' %} Fits AirPods charging cases</li>
        <li>{% render 'icon-check' %} Glow coating recharges with light</li>
        <li>{% render 'icon-check' %} Six color variants: Blue, Green, Purple, Red, White, and Orange</li>
        <li>{% render 'icon-check' %} Includes keyring loop</li>
      </ul>
    </div>
  </div>
</section>

<section class="section">
  <div class="container grid-3">
    <div class="media-tile">
      <img src="{{ 'hero-image.jpg' | asset_url }}" alt="Nocturne Aura Case held at night" width="720" height="617" loading="lazy">
    </div>
    <div class="media-tile">
      <img src="{{ 'lifestyle-desk.jpg' | asset_url }}" alt="Nocturne Aura Case on a desk" width="512" height="512" loading="lazy">
    </div>
    <div class="media-tile">
      <img src="{{ 'lifestyle-lowlight.jpg' | asset_url }}" alt="Nocturne Aura Case in low light" width="1920" height="1920" loading="lazy">
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Nocturne Aura Case"
    },
    {
      "type": "text",
      "id": "display_title",
      "label": "Display title",
      "default": "Nocturne Aura Case"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "Nocturne Aura Case"
    },
    {
      "type": "textarea",
      "id": "short_description",
      "label": "Short description",
      "default": "Minimal by day. Easy to find at night. A protective AirPods case with a phosphorescent finish that recharges under everyday light."
    },
    {
      "type": "text",
      "id": "review_preview",
      "label": "Review preview",
      "default": "4.9/5 from glow-in-the-dark case fans"
    },
    {
      "type": "text",
      "id": "details_eyebrow",
      "label": "Details eyebrow",
      "default": "Product details"
    },
    {
      "type": "text",
      "id": "details_heading",
      "label": "Details heading",
      "default": "Ready for the pocket, desk, and dark."
    },
    {
      "type": "textarea",
      "id": "details_text",
      "label": "Details text",
      "default": "Nocturne Aura Case adds a low-key glow to the item you already reach for every day. Leave it near a lamp, window, or desk light and the finish stores that light for later."
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping text",
      "default": "Free Shipping on All Orders"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Returns text",
      "default": "14-day guarantee"
    },
    {
      "type": "text",
      "id": "checkout_text",
      "label": "Checkout text",
      "default": "Secure checkout"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Product benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Soft phosphorescent glow with no battery or LED"
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Product highlight",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Soft night glow"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Charges from room light or sunlight, then glows gently in the dark."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main product",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Soft phosphorescent glow with no battery or LED" } },
        { "type": "benefit", "settings": { "text": "Slim protective shell for everyday carry" } },
        { "type": "benefit", "settings": { "text": "Built for wired and wireless charging" } },
        { "type": "highlight", "settings": { "title": "Soft night glow", "text": "Charges from room light or sunlight, then glows gently in the dark." } },
        { "type": "highlight", "settings": { "title": "Easy to spot", "text": "Find your AirPods faster on a nightstand, desk, couch, or bag." } },
        { "type": "highlight", "settings": { "title": "Everyday slim", "text": "A clean protective shell that keeps the pocket feel light." } },
        { "type": "highlight", "settings": { "title": "Charging friendly", "text": "Works with wired and wireless charging without removing the case." } }
      ]
    }
  ]
}
{% endschema %}
