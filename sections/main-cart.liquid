<section class="section cart-page">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-lg">{{ section.settings.heading }}</h1>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="cart-layout">
          <div class="cart-items">
            {% for item in cart.items %}
              <article class="cart-item">
                <a class="cart-item__image" href="{{ item.url }}">
                  {% if item.image %}
                    {% assign item_image_alt = item.image.alt | default: item.product.title %}
                    {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item_image_alt }}
                  {% else %}
                    <img src="{{ 'product-blue.jpeg' | asset_url }}" alt="{{ item.product.title | escape }}" width="240" height="240" loading="lazy">
                  {% endif %}
                </a>

                <div class="cart-item__body">
                  <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="text-muted">{{ item.variant.title }}</p>
                  {% endunless %}
                  {% if item.properties.size > 0 %}
                    <dl class="cart-item__properties">
                      {% for property in item.properties %}
                        {% assign property_first_char = property.first | slice: 0 %}
                        {% if property.last != blank and property_first_char != '_' %}
                          <div>
                            <dt>{{ property.first }}:</dt>
                            <dd>{{ property.last }}</dd>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </dl>
                  {% endif %}
                  <label class="selector-label" for="Quantity-{{ forloop.index }}">Quantity</label>
                  <input
                    class="quantity-input"
                    id="Quantity-{{ forloop.index }}"
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    aria-label="Quantity for {{ item.product.title | escape }}"
                  >
                </div>

                <div class="cart-item__price">
                  <strong>{{ item.final_line_price | money }}</strong>
                  {% if item.original_line_price != item.final_line_price %}
                    <s class="text-muted">{{ item.original_line_price | money }}</s>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>

          <aside class="cart-summary">
            <h2 class="heading-md" style="font-size: 1.35rem;">Order summary</h2>
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>
            <p class="text-muted">{{ section.settings.discount_note }}</p>
            <div class="button-stack">
              <button class="button button--outline" type="submit" name="update">Update cart</button>
              <button class="button" type="submit" name="checkout">Checkout</button>
            </div>
          </aside>
        </div>
      </form>
    {% else %}
      <div class="empty-state">
        <p class="text-muted">{{ section.settings.empty_text }}</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">{{ section.settings.empty_cta }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready when you are."
    },
    {
      "type": "textarea",
      "id": "discount_note",
      "label": "Discount note",
      "default": "Bundle savings require matching Shopify automatic discounts or discount codes configured in the admin."
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "empty_cta",
      "label": "Empty cart CTA",
      "default": "Shop Nortune"
    }
  ]
}
{% endschema %}
