<section class="section cart-page" data-cart-section data-cart-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="heading-lg">{{ section.settings.heading }}</h1>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate data-cart-form data-cart-content>
        <div class="cart-layout">
          <div class="cart-items">
            {% for item in cart.items %}
              {% assign display_item_title = item.product.title %}
              {% if item.product.handle == 'null-1776305574568' %}
                {% assign display_item_title = 'Nocturne Aura Case' %}
              {% endif %}
              {% assign cart_fallback_image = 'nocturne-blue.jpeg' | asset_url %}
              {% assign cart_color = '' %}
              {% for property in item.properties %}
                {% if property.first == 'Color' %}
                  {% assign cart_color = property.last %}
                  {% if property.last == 'White' %}
                    {% assign cart_fallback_image = 'nocturne-white.png' | asset_url %}
                  {% elsif property.last == 'Orange' %}
                    {% assign cart_fallback_image = 'nocturne-orange.jpeg' | asset_url %}
                  {% endif %}
                {% endif %}
              {% endfor %}
              <article class="cart-item" data-cart-line data-cart-line-key="{{ item.key | escape }}" aria-live="polite">
                <a class="cart-item__image" href="{{ item.url }}">
                  {% if item.product.handle == 'null-1776305574568' and cart_color != blank %}
                    <img src="{{ cart_fallback_image }}" alt="{{ display_item_title | escape }}" width="240" height="240" loading="lazy">
                  {% elsif item.image %}
                    {% assign item_image_alt = item.image.alt | default: display_item_title %}
                    {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item_image_alt }}
                  {% else %}
                    <img src="{{ cart_fallback_image }}" alt="{{ display_item_title | escape }}" width="240" height="240" loading="lazy">
                  {% endif %}
                </a>

                <div class="cart-item__body">
                  <a class="cart-item__title" href="{{ item.url }}">{{ display_item_title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="text-muted">{{ item.variant.title }}</p>
                  {% endunless %}
                  {% if item.properties.size > 0 %}
                    <dl class="cart-item__properties">
                      {% for property in item.properties %}
                        {% assign property_first_char = property.first | slice: 0 %}
                        {% if property.last != blank and property_first_char != '_' %}
                          <div>
                            <dt>{{ property.first }}:</dt>
                            <dd>{{ property.last }}</dd>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </dl>
                  {% endif %}
                  <label class="selector-label" for="Quantity-{{ forloop.index }}">Quantity</label>
                  <input
                    class="quantity-input"
                    id="Quantity-{{ forloop.index }}"
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    data-cart-quantity
                    data-cart-line-key="{{ item.key | escape }}"
                    aria-label="Quantity for {{ item.product.title | escape }}"
                  >
                  <a
                    class="cart-item__remove"
                    href="{{ item.url_to_remove }}"
                    data-cart-remove
                    data-cart-line-key="{{ item.key | escape }}"
                    aria-label="Remove {{ display_item_title | escape }}"
                  >
                    Remove
                  </a>
                </div>

                <div class="cart-item__price">
                  <strong data-cart-line-price>{{ item.final_line_price | money }}</strong>
                  <s
                    class="text-muted"
                    data-cart-line-compare
                    {% if item.original_line_price == item.final_line_price %}hidden{% endif %}
                  >
                    {{ item.original_line_price | money }}
                  </s>
                </div>
              </article>
            {% endfor %}
          </div>

          <aside class="cart-summary">
            <h2 class="heading-md" style="font-size: 1.35rem;">Order summary</h2>
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <strong data-cart-subtotal>{{ cart.total_price | money }}</strong>
            </div>
            <div
              class="cart-summary__row cart-summary__row--subtle"
              data-cart-shipping
              data-shipping-threshold="3998"
              data-under-threshold-price="$1.99"
            >
              {% comment %}
                TODO Shopify Admin: checkout shipping availability depends on the
                product's General shipping profile covering the customer's market,
                the discounted order subtotal, and the cart's total weight.
              {% endcomment %}
              {% if cart.total_price < 3998 %}
                <span data-cart-shipping-label>Standard Shipping</span>
                <strong data-cart-shipping-value>$1.99</strong>
              {% else %}
                <span data-cart-shipping-label>Shipping</span>
                <strong data-cart-shipping-value>Calculated at checkout</strong>
              {% endif %}
            </div>
            <p class="cart-summary__helper text-muted" data-cart-shipping-helper>
              {% if cart.total_price < 3998 %}
                Orders under $39.98 show the standard $1.99 rule when your Shopify shipping profile covers the order. Final rates are confirmed at checkout.
              {% else %}
                Shipping rates for this order are confirmed by Shopify at checkout.
              {% endif %}
            </p>
            <p class="text-muted">{{ section.settings.discount_note }}</p>
            <p class="cart-status text-muted" data-cart-status role="status" aria-live="polite"></p>
            <div class="button-stack">
              <button class="button button--outline" type="submit" name="update">Update cart</button>
              <button class="button" type="submit" name="checkout">Checkout</button>
            </div>
          </aside>
        </div>
      </form>
      <div class="empty-state" data-cart-empty hidden>
        <p class="text-muted">{{ section.settings.empty_text }}</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">{{ section.settings.empty_cta }}</a>
      </div>
    {% else %}
      <div class="empty-state" data-cart-empty>
        <p class="text-muted">{{ section.settings.empty_text }}</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">{{ section.settings.empty_cta }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready when you are."
    },
    {
      "type": "textarea",
      "id": "discount_note",
      "label": "Discount note",
      "default": "Bundle savings apply automatically. Checkout uses your Shopify shipping profile and rate rules."
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "empty_cta",
      "label": "Empty cart CTA",
      "default": "Shop Nocturne"
    }
  ]
}
{% endschema %}
